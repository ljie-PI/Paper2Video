# Optional service integrations
MINERU_API_KEY=
MINERU_API_URL=https://mineru.net
MINERU_UPLOAD_PATH=/api/v1/file/upload
MINERU_STATUS_PATH_TEMPLATE=/api/v1/file/status/{taskId}
MINERU_RESULT_PATH_TEMPLATE=/api/v1/file/result/{taskId}
LOG_LEVEL=INFO

# Optional LLM configuration (OpenAI-compatible, Anthropic, or Gemini)
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_MAX_TOKENS=
USE_LLM_CACHE=true

TTS_MODEL_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry
TTS_API_KEY=
USE_TTS_CACHE=true

# Provider-specific fallbacks (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GEMINI_API_KEY=
GEMINI_BASE_URL=
QWEN_API_KEY=
